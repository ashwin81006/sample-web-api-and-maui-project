<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ReviewFlow.MAUI.MainPage"
    BackgroundColor="{AppThemeBinding Light=#F4F6F9, Dark=#121212}">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="18">

            <Label
                Text="ReviewFlow Demo"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Entry
                x:Name="ReviewIdEntry"
                Placeholder="Enter Review ID"
                Keyboard="Numeric"
                ClearButtonVisibility="WhileEditing" />

            <HorizontalStackLayout Spacing="10">

                <Button
                    Text="Get Review"
                    HorizontalOptions="FillAndExpand"
                    Clicked="GetReviewClicked"/>

                <Button
                    Text="Get All"
                    HorizontalOptions="FillAndExpand"
                    Clicked="GetAllClicked"/>

            </HorizontalStackLayout>

            <Label
                x:Name="LastSyncLabel"
                Text="Last Sync : Never"
                FontSize="12"
                TextColor="Gray"
                HorizontalOptions="Center"/>

            <Frame
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                BorderColor="{AppThemeBinding Light=#D9D9D9, Dark=#404040}"
                CornerRadius="12"
                Padding="15"
                HasShadow="True">

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="Review Details"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Label
                        x:Name="StudentLabel"
                        Text="Student : -"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Label
                        x:Name="FacultyLabel"
                        Text="Faculty : -"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Label
                        x:Name="ProjectLabel"
                        Text="Project : -"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Label
                        x:Name="StatusLabel"
                        Text="Status : -"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                </VerticalStackLayout>

            </Frame>

            <Label
                Text="API Activity"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <CollectionView
    x:Name="LogCollection"
    HeightRequest="220">

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Frame
                Margin="0,5"
                Padding="10"
                CornerRadius="8"
                BorderColor="{AppThemeBinding Light=#DDDDDD, Dark=#404040}"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

                            <Label
                    Text="{Binding}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                        </Frame>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>